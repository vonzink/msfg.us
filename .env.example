# MSFG.us environment template. Copy to `.env` and fill in real values.
# `.env*` is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Database (REQUIRED). Postgres is the system-of-record.
# ---------------------------------------------------------------------------
# Pooled/app connection used at runtime by the Prisma driver adapter.
DATABASE_URL="postgresql://user:pass@localhost:5432/msfg_dev?schema=public"
# Direct (non-pooled) connection used by `prisma migrate` (via prisma.config.ts).
# Set this when DATABASE_URL points at a pooler (Supabase/Neon/PgBouncer);
# otherwise it can mirror DATABASE_URL. Optional.
DIRECT_URL="postgresql://user:pass@localhost:5432/msfg_dev?schema=public"

# ---------------------------------------------------------------------------
# Go High Level / LeadConnector CRM (OPTIONAL).
# Lead sync is DISABLED unless GHL_API_TOKEN *and* GHL_LOCATION_ID are set;
# leads are still saved to Postgres and marked SKIPPED.
# ---------------------------------------------------------------------------
# API base host (default shown). Override only for a region/sandbox host.
GHL_API_BASE="https://services.leadconnectorhq.com"
# GHL API version header (default shown).
GHL_API_VERSION="2021-07-28"
# Private Integration / OAuth access token (Bearer).
GHL_API_TOKEN=""
# Sub-account (location) id leads are written into.
GHL_LOCATION_ID=""
# Pipeline + stage for created opportunities. Without both, the contact is
# upserted but no opportunity is created (graceful skip).
GHL_PIPELINE_ID=""
GHL_STAGE_ID=""

# --- Inbound GHL webhooks (two-way sync) — OPTIONAL -------------------------
# CRM → site sync. GHL pushes contact/opportunity/pipeline-stage events to
#   POST /api/v1/webhooks/ghl
# and we mirror the status onto the matching Lead (crmStatus / crmStageId).
# Inbound is DISABLED unless ONE verification mode below is configured: with
# none set, deliveries are acknowledged (200) but NOT processed. Mode is chosen
# by which var is set (HMAC takes precedence over public-key):
#
#   (a) HMAC shared secret — for custom/automation webhooks that sign the raw
#       body with a shared secret (HMAC-SHA256, hex or base64).
GHL_WEBHOOK_SECRET=""
#   (b) Public-key verification — GHL MARKETPLACE webhooks are asymmetrically
#       signed: Ed25519 in `X-GHL-Signature` (current) and RSA-SHA256 in
#       `X-WH-Signature` (legacy, deprecates 2026-07-01). The verifier ships
#       with GHL's published public keys, so to enable this mode WITHOUT an
#       override just set the flag below to "true". Provide a PEM here only to
#       override the built-in keys (rarely needed).
GHL_WEBHOOK_PUBLIC_KEY_VERIFY=""
GHL_WEBHOOK_PUBLIC_KEY=""

# ---------------------------------------------------------------------------
# Internal cron (OPTIONAL).
# ---------------------------------------------------------------------------
# When set, /api/internal/retry-ghl requires `Authorization: Bearer <secret>`.
# Configure the same value as the Vercel Cron secret. Leave empty in dev.
CRON_SECRET=""

# ---------------------------------------------------------------------------
# DeepSeek (OpenAI-compatible) (OPTIONAL) — powers the homepage AI assistant.
# Without DEEPSEEK_API_KEY the assistant is DISABLED and the chat endpoint
# returns a graceful "unavailable" message (call us / start your application);
# the rest of the site is unaffected. Cost-effective; tool calling requires the
# `deepseek-chat` model (deepseek-reasoner does NOT support functions).
# Server-only — never expose as NEXT_PUBLIC_*.
# ---------------------------------------------------------------------------
# Secret API key from platform.deepseek.com.
DEEPSEEK_API_KEY=""
# Base URL + model. Defaults target DeepSeek; override for any OpenAI-compatible
# endpoint (OpenAI, Together, a local model, etc.).
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ---------------------------------------------------------------------------
# AWS Cognito SSO (OPTIONAL) — sign-in / sign-up + SSO into app.msfgco.com.
# Auth is treated as CONFIGURED only when COGNITO_CLIENT_ID *and*
# COGNITO_HOSTED_UI_DOMAIN are set. With either missing, the auth routes return
# a clear "not configured" response and the apply wizard's account step stays
# the legacy mock — the site builds/runs unchanged. SERVER-ONLY (never expose
# any of these as NEXT_PUBLIC_*).
#
# Reuses the user pool shared with app.msfgco.com (region us-west-1, pool
# us-west-1_S6iE2uego — defaults below). YOU MUST register a DEDICATED app
# client for msfg.us in that pool and supply:
#   • COGNITO_CLIENT_ID            — the new app client id.
#   • COGNITO_HOSTED_UI_DOMAIN     — the pool's Hosted UI / managed-login domain.
#   • COGNITO_CLIENT_SECRET        — ONLY for a confidential client (optional).
# and, in the Cognito app-client settings, REGISTER these URLs:
#   • Allowed callback URL  = AUTH_REDIRECT_URI         (default <site>/auth/callback)
#   • Allowed sign-out URL  = AUTH_LOGOUT_REDIRECT_URI  (default <site>)
# OAuth grant: Authorization code. Allowed scopes must include `openid`
# (required to receive an id_token) plus `email`/`profile`.
# ---------------------------------------------------------------------------
# Region + user pool (defaults match the shared app.msfgco.com pool).
COGNITO_REGION="us-west-1"
COGNITO_USER_POOL_ID="us-west-1_S6iE2uego"
# Dedicated app client id for msfg.us (REQUIRED to enable auth).
COGNITO_CLIENT_ID=""
# Client secret — set ONLY for a confidential app client (sent as HTTP Basic /
# client_secret_basic on the token endpoint). Leave empty for a public client
# (PKCE is always used regardless).
COGNITO_CLIENT_SECRET=""
# Hosted UI / managed-login domain (REQUIRED to enable auth). No trailing slash.
# e.g. https://msfg.auth.us-west-1.amazoncognito.com  (prefix domain) or your
# custom auth domain https://login.msfg.us
COGNITO_HOSTED_UI_DOMAIN=""
# Space-delimited OAuth scopes (default shown). `openid` is mandatory.
COGNITO_SCOPES="openid email profile"
# OAuth redirect (callback) URI — must be an Allowed callback URL on the client.
# Defaults to ${NEXT_PUBLIC_SITE_URL}/auth/callback when empty.
AUTH_REDIRECT_URI=""
# Post-logout redirect — must be an Allowed sign-out URL on the client.
# Defaults to ${NEXT_PUBLIC_SITE_URL} when empty.
AUTH_LOGOUT_REDIRECT_URI=""

# ---------------------------------------------------------------------------
# Loan Origination System (LOS) hand-off (OPTIONAL).
# Base URL of the mortgage-app API (app.msfgco.com). Enables the apply-funnel
# hand-off: POST {LOS_API_BASE}/api/loan-applications/intake with the user's
# Cognito id_token. Unset → hand-off skipped (lead still captured; SSO CTA still
# shown). SERVER-ONLY.
# ---------------------------------------------------------------------------
LOS_API_BASE=""

# ---------------------------------------------------------------------------
# Address autocomplete — Google Places API (New) (OPTIONAL).
# Powers the apply-wizard "What home are you..." address step. The browser
# only ever calls our same-origin proxy (/api/v1/address/{suggest,details});
# this key is used SERVER-SIDE via the X-Goog-Api-Key header and is NEVER
# exposed to the client (do NOT use a NEXT_PUBLIC_* var). When empty, the
# address field silently degrades to a validated free-text input — the funnel
# never breaks. See src/server/integrations/address/googlePlaces.ts.
# Setup: enable "Places API (New)" on the GCP project (billing on); create an
# API key; restrict it API-wise to "Places API (New)" ONLY; application
# restriction = None or server IPs (NOT HTTP referrers — calls are server-side).
# ---------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=""

# ---------------------------------------------------------------------------
# Public partner API (`/api/v1/public/*`) — OPTIONAL.
# Versioned, key-authenticated API for external integrators (separate from the
# site's own same-origin endpoints, which stay key-free). Degrades gracefully
# with no config: READ endpoints (rates / programs / loan-officers / openapi)
# stay OPEN + rate-limited; the key-gated WRITE endpoint (POST .../leads)
# returns 503 "Public API not enabled" until at least one key exists. Keys can
# also be stored in the DB (additive ApiKey model) — the validator checks env
# keys first, then DB. SERVER-ONLY (never expose as NEXT_PUBLIC_*).
# ---------------------------------------------------------------------------
# Comma-separated API keys. Each entry is either a BARE key (`<key>`) or a
# `keyId:key:secret` triple. A `secret` enables HMAC on write endpoints:
#   x-signature: sha256=<HMAC-SHA256(secret, rawBody)>  (constant-time compare).
# Mint a key: generate a random string (e.g. `openssl rand -hex 32`) and put it
# here (optionally `partnerName:<key>:<secret>`). For DB-backed keys, store
# sha256(key) in api_keys.keyHash. Leave empty to keep the write endpoint 503.
MSFG_API_KEYS=""
# Requests/minute for the in-memory token-bucket limiter, keyed by
# (apiKey || client IP). Default 60. NOTE: in-memory ⇒ per-serverless-instance;
# a distributed limiter (Upstash/Postgres) is the production upgrade.
PUBLIC_API_RATE_RPM="60"
# Comma-separated allowed CORS origins for the public API. Default "*" (reads
# are public). Set explicit origins (e.g. https://partner.example.com) to lock
# down browser callers.
PUBLIC_API_CORS_ORIGINS="*"

# ---------------------------------------------------------------------------
# Generic webhook (OPTIONAL) — example `hmac` provider.
# POST /api/v1/webhooks/hmac verifies `x-signature` (HMAC-SHA256 of the raw
# body) against this shared secret, dedupes + logs via the event log, then runs
# a no-op handler. With no secret set it stays permissive off-production and is
# rejected in production. New providers are a single registry entry (see
# src/server/webhooks/registry.ts).
# ---------------------------------------------------------------------------
GENERIC_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Sentry (OPTIONAL, follow-up seam). The Sentry SDK is intentionally NOT
# installed yet (keeps deps light). captureError() in src/lib/log.ts no-ops
# unless wired; set this ahead of time and add Sentry.captureException there as
# a follow-up. Vercel Analytics + Speed Insights are already mounted in
# layout.tsx and no-op outside Vercel/dev (no env needed).
# ---------------------------------------------------------------------------
SENTRY_DSN=""

# ---------------------------------------------------------------------------
# Public site config (client-exposed — safe to commit real values).
# Consumed by the frontend (src/content/site.ts, layout.tsx). NOT read by the
# server env module.
# ---------------------------------------------------------------------------
# Canonical site URL (used for metadata/canonical links).
NEXT_PUBLIC_SITE_URL="https://msfg.us"
# Deploy environment: "development" | "preview" | "production".
NEXT_PUBLIC_SITE_ENV="development"
# MSFG app (LOS borrower portal) URL — target of the apply wizard's "Continue
# in the MSFG app" deep link after a signed-in completion. PUBLIC (inlined into
# the client bundle). Default shown.
NEXT_PUBLIC_APP_URL="https://app.msfgco.com"

# --- GHL / LeadConnector widgets (client-exposed) — OPTIONAL ----------------
# These are PUBLIC widget ids (safe to expose); they are NOT read by the server
# env module. Each feature renders nothing / falls back when its id is unset.
#
# Schedule-a-call (GHL Calendars). Default booking calendar id; the booking
# iframe is `${NEXT_PUBLIC_GHL_CALENDAR_BASE}/widget/booking/<id>`. Per-officer
# overrides live in src/content/officers.ts (Officer.calendarId). With no id,
# the "Schedule" / "Talk to a loan officer" actions link to their fallback href.
NEXT_PUBLIC_GHL_CALENDAR_ID=""
# Booking embed host (default shown — LeadConnector). Override for a custom
# white-label domain, e.g. https://link.yourbrand.com
NEXT_PUBLIC_GHL_CALENDAR_BASE="https://api.leadconnectorhq.com"
#
# LeadConnector live-agent chat widget (mounted site-wide in layout.tsx, lazy).
# Renders nothing unless the widget id is set. This is the live/CRM chat —
# distinct from the homepage AI assistant.
NEXT_PUBLIC_GHL_CHAT_WIDGET_ID=""
# Optional overrides for the loader (defaults target widgets.leadconnectorhq.com).
NEXT_PUBLIC_GHL_CHAT_RESOURCES_URL=""
NEXT_PUBLIC_GHL_CHAT_LOADER_SRC=""
# Optional: scope the chat widget to a GHL location/sub-account id (client-side).
# (Separate from the server-only GHL_LOCATION_ID used for the API.)
NEXT_PUBLIC_GHL_LOCATION_ID=""
